 </head>
 <body>
  <div class="app-wrapper">
   <header class="game-header">
    <h1 class="game-title" id="gameTitle">Sustainability Match-Up v4.1</h1>
    <div class="level-title" id="levelTitle">
     Level 1: Foundation
    </div>
   </header>
   <div class="dashboard">
    <div class="stat-box">
     <div class="stat-label">
      Level
     </div>
     <div class="stat-value" id="currentLevel">
      1
     </div>
    </div>
    <div class="stat-box timer">
     <div class="stat-label">
      Time Left
     </div>
     <div class="stat-value" id="timer">
      2:00
     </div>
    </div>
    <div class="stat-box">
     <div class="stat-label">
      Matches
     </div>
     <div class="stat-value">
      <span id="matches">0</span>/<span id="totalMatches">5</span>
     </div>
    </div>
   </div>
   <div class="progress-container">
    <div class="progress-bar">
     <div class="progress-fill" id="progressFill" style="width: 0%">
      0%
     </div>
    </div>
   </div>
   <div class="game-board level-1" id="gameBoard"></div>
   <div class="controls"><button class="btn btn-start" id="startBtn">Start Game</button> <button class="btn btn-restart" id="restartBtn" style="display:none;">Restart Level</button>
   </div>
   <div class="message-overlay" id="messageOverlay">
    <div class="message-box">
     <div class="message-icon" id="messageIcon">
      🎉
     </div>
     <div class="message-text" id="messageText">
      Level Complete!
     </div>
     <div class="message-subtext" id="messageSubtext">
      Great job! Ready for the next challenge?
     </div><button class="btn btn-next" id="actionBtn">Next Level</button>
    </div>
   </div>
  </div>
  <script>
    // ===== CONFIGURATION =====
    const defaultConfig = {
      game_title: "Sustainability Match-Up v4.1",
      level_1_title: "Level 1: Foundation",
      level_2_title: "Level 2: Intermediate",
      level_3_title: "Level 3: Advanced",
      start_button_text: "Start Game",
      next_level_button_text: "Next Level",
      try_again_button_text: "Try Again",
      champion_message: "Climate Champion!",
      game_over_message: "Time's Up!",
      background_color: "#667eea",
      habit_card_color: "#3b82f6",
      category_card_color: "#10b981",
      button_color: "#10b981",
      timer_color: "#ef4444"
    };

    // ===== GAME DATA =====
    const levelsData = {
      1: {
        time: 120,
        cards: [
          { id: 1, type: 'habit', icon: '♻️', text: 'Recycling plastic bottles', match: 'recycling', feedback: 'Correct! Recycling keeps plastic out of landfills and oceans.' },
          { id: 2, type: 'category', icon: '♻️', text: 'Recycling', match: 'recycling' },
          { id: 3, type: 'habit', icon: '🗑️', text: 'Sorting household waste', match: 'segregation', feedback: 'Great! Waste segregation helps recycle materials properly.' },
          { id: 4, type: 'category', icon: '🗄️', text: 'Waste Segregation', match: 'segregation' },
          { id: 5, type: 'habit', icon: '🥬', text: 'Composting food scraps', match: 'organic', feedback: 'Excellent! Composting returns nutrients to soil and reduces methane.' },
          { id: 6, type: 'category', icon: '🌾', text: 'Organic Waste Management', match: 'organic' },
          { id: 7, type: 'habit', icon: '👕', text: 'Buying second-hand clothes', match: 'circular', feedback: 'Perfect! Reusing products reduces demand for new manufacturing.' },
          { id: 8, type: 'category', icon: '🔄', text: 'Circular Economy', match: 'circular' },
          { id: 9, type: 'habit', icon: '💡', text: 'Turning off unused lights', match: 'energy', feedback: 'Correct! Simple actions save energy and reduce carbon emissions.' },
          { id: 10, type: 'category', icon: '⚡', text: 'Energy Efficiency', match: 'energy' }
        ]
      },
      2: {
        time: 90,
        cards: [
          { id: 11, type: 'habit', icon: '☀️', text: 'Using solar lamps', match: 'renewable', feedback: 'Great! Solar energy is clean, renewable, and reduces fossil fuel use.' },
          { id: 12, type: 'category', icon: '🌞', text: 'Renewable Energy', match: 'renewable' },
          { id: 13, type: 'habit', icon: '🔥', text: 'Using clean cookstoves', match: 'cooking', feedback: 'Excellent! Clean cookstoves reduce indoor air pollution and save fuel.' },
          { id: 14, type: 'category', icon: '🍳', text: 'Clean Cooking Solutions', match: 'cooking' },
          { id: 15, type: 'habit', icon: '🌧️', text: 'Harvesting rainwater', match: 'water', feedback: 'Perfect! Rainwater harvesting conserves water and reduces runoff.' },
          { id: 16, type: 'category', icon: '💧', text: 'Water Conservation', match: 'water' },
          { id: 17, type: 'habit', icon: '🚌', text: 'Taking public transport', match: 'lowcarbon', feedback: 'Correct! Shared transport reduces per-person carbon emissions.' },
          { id: 18, type: 'category', icon: '🚍', text: 'Low-Carbon Transport', match: 'lowcarbon' },
          { id: 19, type: 'habit', icon: '🚲', text: 'Cycling to work', match: 'active', feedback: 'Great! Active transport has zero emissions and improves health.' },
          { id: 20, type: 'category', icon: '🚴', text: 'Active Transport', match: 'active' }
        ]
      },
      3: {
        time: 60,
        cards: [
          { id: 21, type: 'habit', icon: '🌳', text: 'Planting trees', match: 'nature', feedback: 'Excellent! Trees absorb CO2, cool cities, and support biodiversity.' },
          { id: 22, type: 'category', icon: '🌿', text: 'Nature-Based Solutions', match: 'nature' },
          { id: 23, type: 'habit', icon: '🌲', text: 'Agroforestry practices', match: 'sequestration', feedback: 'Perfect! Agroforestry captures carbon while producing food.' },
          { id: 24, type: 'category', icon: '🌍', text: 'Carbon Sequestration', match: 'sequestration' },
          { id: 25, type: 'habit', icon: '🛍️', text: 'Using reusable bags', match: 'consumption', feedback: 'Correct! Reducing single-use items cuts waste and resource use.' },
          { id: 26, type: 'category', icon: '♻️', text: 'Sustainable Consumption', match: 'consumption' },
          { id: 27, type: 'habit', icon: '📢', text: 'Advocating for climate policies', match: 'advocacy', feedback: 'Great! Policy change drives systemic climate action.' },
          { id: 28, type: 'category', icon: '🎯', text: 'Climate Advocacy', match: 'advocacy' },
          { id: 29, type: 'habit', icon: '🚜', text: 'Mulching & soil-cover farming', match: 'agriculture', feedback: 'Excellent! These practices improve soil health and store carbon.' },
          { id: 30, type: 'category', icon: '🌽', text: 'Climate-Smart Agriculture', match: 'agriculture' }
        ]
      }
    };

    let currentLevel = 1;
    let timeLeft = 120;
    let timerInterval = null;
    let matchedPairs = 0;
    let totalPairs = 5;
    let gameActive = false;
    let allCards = [];
    let draggedElement = null;
    let matchedCardIds = new Set();

    // ===== SOUND EFFECTS (Using Web Audio API) =====
    const audioContext = new (window.AudioContext || window.webkitAudioContext)();

    function playSound(type) {
      try {
        const oscillator = audioContext.createOscillator();
        const gainNode = audioContext.createGain();
        
        oscillator.connect(gainNode);
        gainNode.connect(audioContext.destination);
        
        if (type === 'correct') {
          oscillator.frequency.value = 800;
          gainNode.gain.setValueAtTime(0.2, audioContext.currentTime);
          gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.2);
          oscillator.start(audioContext.currentTime);
          oscillator.stop(audioContext.currentTime + 0.2);
        } else if (type === 'wrong') {
          oscillator.frequency.value = 200;
          gainNode.gain.setValueAtTime(0.15, audioContext.currentTime);
          gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.15);
          oscillator.start(audioContext.currentTime);
          oscillator.stop(audioContext.currentTime + 0.15);
        } else if (type === 'win') {
          [523, 659, 784].forEach((freq, i) => {
            const osc = audioContext.createOscillator();
            const gain = audioContext.createGain();
            osc.connect(gain);
            gain.connect(audioContext.destination);
            osc.frequency.value = freq;
            gain.gain.setValueAtTime(0.2, audioContext.currentTime + i * 0.1);
            gain.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + i * 0.1 + 0.3);
            osc.start(audioContext.currentTime + i * 0.1);
            osc.stop(audioContext.currentTime + i * 0.1 + 0.3);
          });
        }
      } catch (e) {
        // Silently fail if audio context not available
      }
    }

    // ===== UTILITY FUNCTIONS =====
    function shuffleArray(array) {
      const newArray = [...array];
      for (let i = newArray.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [newArray[i], newArray[j]] = [newArray[j], newArray[i]];
      }
      return newArray;
    }

    function formatTime(seconds) {
      const mins = Math.floor(seconds / 60);
      const secs = seconds % 60;
      return `${mins}:${secs.toString().padStart(2, '0')}`;
    }

    function showFeedback(message, isError = false) {
      const existingToast = document.querySelector('.feedback-toast');
      if (existingToast) {
        existingToast.remove();
      }

      const toast = document.createElement('div');
      toast.className = `feedback-toast ${isError ? 'error' : ''}`;
      toast.textContent = message;
      document.body.appendChild(toast);

      setTimeout(() => {
        toast.remove();
      }, 3000);
    }

    // ===== GAME FUNCTIONS =====
    function initLevel(level) {
      currentLevel = level;
      const levelData = levelsData[level];
      timeLeft = levelData.time;
      totalPairs = levelData.cards.length / 2;
      matchedPairs = 0;
      gameActive = true;
      matchedCardIds = new Set();

      // Mix all cards together and shuffle
      allCards = shuffleArray([...levelData.cards]);

      // Update UI
      document.getElementById('currentLevel').textContent = level;
      document.getElementById('timer').textContent = formatTime(timeLeft);
      document.getElementById('matches').textContent = '0';
      document.getElementById('totalMatches').textContent = totalPairs;
      updateProgress();

      // Update level title
      const levelTitles = [
        defaultConfig.level_1_title,
        defaultConfig.level_2_title,
        defaultConfig.level_3_title
      ];
      document.getElementById('levelTitle').textContent = levelTitles[level - 1];

      // Update board class
      const board = document.getElementById('gameBoard');
      board.className = `game-board level-${level}`;

      // Render cards
      renderCards();

      // Start timer
      startTimer();
    }

    function renderCards() {
      const board = document.getElementById('gameBoard');
      board.innerHTML = '';

      // Render all cards mixed together
      allCards.forEach(card => {
        const cardElement = document.createElement('div');
        const cardClass = card.type === 'habit' ? 'habit-card' : 'category-card';
        cardElement.className = `card ${cardClass} draggable`;
        cardElement.draggable = true;
        cardElement.dataset.id = card.id;
        cardElement.dataset.match = card.match;
        cardElement.dataset.type = card.type;
        if (card.feedback) {
          cardElement.dataset.feedback = card.feedback;
        }

        const badgeText = card.type === 'habit' ? 'H' : 'C';

        cardElement.innerHTML = `
          <div class="card-badge">${badgeText}</div>
          <div class="card-icon">${card.icon}</div>
          <div class="card-text">${card.text}</div>
        `;

        // Add drag event listeners
        cardElement.addEventListener('dragstart', handleDragStart);
        cardElement.addEventListener('dragend', handleDragEnd);
        cardElement.addEventListener('dragover', handleDragOver);
        cardElement.addEventListener('dragleave', handleDragLeave);
        cardElement.addEventListener('drop', handleDrop);
        
        // Touch support for mobile
        cardElement.addEventListener('touchstart', handleTouchStart);
        cardElement.addEventListener('touchmove', handleTouchMove);
        cardElement.addEventListener('touchend', handleTouchEnd);
        
        board.appendChild(cardElement);
      });
    }

    // ===== DRAG AND DROP HANDLERS =====
    
    function handleDragStart(e) {
      if (!gameActive) return;
      
      const card = e.currentTarget;
      
